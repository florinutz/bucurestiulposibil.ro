{
  "name": "next-starter-template",
  "description": "Build a full-stack web application with Next.js.",
  "cloudflare": {
    "label": "Next.js Framework Starter",
    "products": [
      "Workers"
    ],
    "categories": [],
    "icon_urls": [
      "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/5ca0ca32-e897-4699-d4c1-6b680512f000/public"
    ],
    "preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/e42eec61-db86-49c8-7b29-c3ed4783e400/public",
    "publish": true
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.3.0",
    "@sanity/client": "^7.8.2",
    "@sanity/image-url": "^1.1.0",
    "@sanity/ui": "^2.16.7",
    "@sanity/vision": "^3.99.0",
    "@sanity/webhook": "^4.0.4",
    "@types/leaflet": "^1.9.20",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.525.0",
    "next": "15.3.3",
    "next-sanity": "^9.12.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sanity": "^3.99.0",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3",
    "@tailwindcss/postcss": "4.1.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.4",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "9.27.0",
    "eslint-config-next": "15.3.3",
    "msw": "^2.10.4",
    "tailwindcss": "4.1.1",
    "typescript": "5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.26.1"
  },
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types --env-interface CloudflareEnv env.d.ts",
    "build": "npm run cf-typegen && next build",
    "build:cloudflare": "npm run cf-typegen && opennextjs-cloudflare build",
    "check": "npm run cf-typegen && npm run build && tsc",
    "deploy": "npm run cf-typegen && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "dev": "npm run cf-typegen && next dev",
    "lint": "next lint",
    "preview": "npm run cf-typegen && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "next start",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "wrangler d1 execute dots --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute dots --file=./schema.sql --remote",
    "db:reset": "wrangler d1 execute dots --command=\"DROP TABLE IF EXISTS geopoints\" && npm run db:migrate",
    "db:reset:remote": "wrangler d1 execute dots --command=\"DROP TABLE IF EXISTS geopoints\" --remote && npm run db:migrate:remote",
    "db:seed": "wrangler d1 execute dots --file=./seed.sql",
    "db:seed:remote": "wrangler d1 execute dots --file=./seed.sql --remote",
    "db:shell": "wrangler d1 execute dots --interactive",
    "db:shell:remote": "wrangler d1 execute dots --interactive --remote",
    "db:info": "wrangler d1 info dots",
    "db:backup": "wrangler d1 export dots --output=./backup.sql",
    "db:backup:remote": "wrangler d1 export dots --output=./backup.sql --remote",
    "db:restore": "wrangler d1 execute dots --file=./backup.sql",
    "db:restore:remote": "wrangler d1 execute dots --file=./backup.sql --remote",
    "db:count": "wrangler d1 execute dots --command=\"SELECT COUNT(*) as count FROM geopoints\"",
    "db:count:remote": "wrangler d1 execute dots --command=\"SELECT COUNT(*) as count FROM geopoints\" --remote",
    "db:list": "wrangler d1 execute dots --command=\"SELECT id, title, created_at FROM geopoints ORDER BY created_at DESC LIMIT 10\"",
    "db:list:remote": "wrangler d1 execute dots --command=\"SELECT id, title, created_at FROM geopoints ORDER BY created_at DESC LIMIT 10\" --remote"
  }
}
